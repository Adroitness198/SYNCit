
    @{
        ViewData["Title"] = "SYNCit - Analyse";
    }


    <!-- Loading Spinner Overlay -->
    <div class="spinner-overlay" id="loadingOverlay">
        <div class="spinner-border text-light" style="width: 4rem; height: 4rem;" role="status"></div>
        <p class="spinner-text">Analysing your CV with AI...</p>
        <p style="color:rgba(255,255,255,0.4); font-size:0.85rem;">This may take a few seconds</p>
    </div>

    <div class="analyse-section">
        <div class="container" style="max-width: 800px;">
            <div class="card p-4">
                <h2 class="text-center mb-1" style="color:#fff; font-weight:800;">SYNC<span style="color:#007baf;">it</span></h2>
                <p class="text-center mb-4" style="color:rgba(255,255,255,0.7);">Sync Your CV to the Job</p>
                <hr style="border-color:rgba(255,255,255,0.2);">

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form method="post" asp-action="Analyse" enctype="multipart/form-data" id="analyseForm">
                    <div class="mb-3">
                        <label class="form-label text-white">Upload Your CV</label>
                        <input type="file" name="cvFile" class="form-control" accept=".txt,.docx" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-white">Paste Job Description</label>
                        <textarea name="jobDescription" class="form-control" rows="10" placeholder="Paste the job description here..."></textarea>
                    </div>
                    <div class="text-center">
                        <button type="submit" class="btn btn-primary px-5" id="submitBtn" style="border-radius:30px;">
                            Analyse Match →
                        </button>
                    </div>
                </form>

                <div class="text-center mt-3">
                    <a asp-controller="Home" asp-action="Index" style="color:rgba(255,255,255,0.5); font-size:0.9rem;">← Back to Home</a>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            document.getElementById('analyseForm').addEventListener('submit', function () {
                document.getElementById('loadingOverlay').classList.add('active');
                document.getElementById('submitBtn').disabled = true;
            });
        </script>
    }
</div>